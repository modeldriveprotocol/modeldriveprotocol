{
  "name": "modeldriveprotocol",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "pnpm --filter @modeldriveprotocol/protocol build && pnpm --filter @modeldriveprotocol/client build && pnpm --filter @modeldriveprotocol/server build && pnpm --filter @modeldriveprotocol/vscode-extension build && pnpm --filter @modeldriveprotocol/chrome-extension build",
    "changeset": "changeset",
    "clean": "node scripts/clean.mjs",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "publish:packages": "changeset publish",
    "release": "pnpm build && pnpm publish:packages",
    "typecheck": "tsc -b tsconfig.json --pretty false && pnpm --filter @modeldriveprotocol/vscode-extension typecheck && pnpm --filter @modeldriveprotocol/chrome-extension typecheck",
    "test": "pnpm test:unit && pnpm test:smoke",
    "test:unit": "vitest run",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:watch": "vitest",
    "version-packages": "changeset version",
    "docs:dev": "node scripts/prepare-docs.mjs && vitepress dev docs",
    "docs:build": "node scripts/prepare-docs.mjs && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@antfu/eslint-config": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^24.0.0",
    "dprint": "^0.50.2",
    "esbuild": "^0.25.12",
    "eslint": "^9.38.0",
    "jsdom": "^26.1.0",
    "mermaid": "^11.12.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
