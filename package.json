{
  "name": "modeldriveprotocol",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --filter './apps/**' --if-present run build",
    "build:apps": "pnpm -r --filter './apps/**' --if-present run build",
    "build:docs-deps": "pnpm -r --filter './packages/client' --filter './apps/browser-simple-mdp-client' run build",
    "build:packages": "pnpm -r --filter './packages/**' --if-present run build",
    "changeset": "pnpm exec changeset",
    "clean": "node scripts/clean.mjs",
    "docs:sync": "node scripts/sync-generated-docs.mjs",
    "docs:sync:check": "node scripts/sync-generated-docs.mjs --check",
    "docs:prepare": "pnpm run build:docs-deps && node scripts/prepare-docs.mjs",
    "docs:dev": "pnpm run docs:prepare && pnpm exec vitepress dev docs",
    "docs:build": "pnpm run docs:prepare && pnpm exec vitepress build docs",
    "docs:preview": "pnpm exec vitepress preview docs",
    "format": "pnpm exec dprint fmt",
    "format:check": "pnpm exec dprint check",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "publish:packages": "pnpm exec changeset publish",
    "release": "pnpm run build && pnpm run publish:packages",
    "test": "pnpm run test:unit && pnpm run test:smoke",
    "test:smoke": "pnpm run build:packages && node scripts/smoke-test.mjs",
    "test:unit": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest",
    "typecheck": "pnpm run typecheck:packages && pnpm run typecheck:apps",
    "typecheck:apps": "pnpm -r --filter './apps/**' --if-present run typecheck",
    "typecheck:packages": "pnpm exec tsc -b tsconfig.json --pretty false",
    "version-packages": "pnpm exec changeset version"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.0.0",
    "@changesets/cli": "^2.30.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^24.0.0",
    "dprint": "^0.50.2",
    "esbuild": "^0.25.12",
    "eslint": "^9.38.0",
    "jsdom": "^26.1.0",
    "mermaid": "^11.12.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.12.0",
    "vitest": "^3.2.4"
  }
}
