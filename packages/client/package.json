{
  "name": "@modeldriveprotocol/client",
  "version": "2.1.0",
  "type": "module",
  "license": "MIT",
  "description": "JavaScript client SDK and browser bundle for Model Drive Protocol.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/modeldriveprotocol/modeldriveprotocol#readme",
  "bugs": {
    "url": "https://github.com/modeldriveprotocol/modeldriveprotocol/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modeldriveprotocol/modeldriveprotocol.git",
    "directory": "packages/client"
  },
  "keywords": [
    "mdp",
    "mcp",
    "client",
    "sdk",
    "browser"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pure": {
      "types": "./dist/pure.d.ts",
      "default": "./dist/pure.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./global": {
      "default": "./dist/modeldriveprotocol-client.global.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modeldriveprotocol/protocol": "workspace:*",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  },
  "scripts": {
    "build": "tsc -b && node ./scripts/bundle.mjs",
    "clean": "node ../../scripts/clean.mjs",
    "test": "vitest run test"
  }
}
