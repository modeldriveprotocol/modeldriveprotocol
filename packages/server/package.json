{
  "name": "@modeldriveprotocol/server",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "MDP server runtime and fixed MCP bridge for Model Drive Protocol.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/modeldriveprotocol/modeldriveprotocol#readme",
  "bugs": {
    "url": "https://github.com/modeldriveprotocol/modeldriveprotocol/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modeldriveprotocol/modeldriveprotocol.git",
    "directory": "packages/server"
  },
  "keywords": [
    "mdp",
    "mcp",
    "server",
    "bridge",
    "agent"
  ],
  "bin": {
    "modeldriveprotocol-server": "./dist/cli.js",
    "mdp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@modeldriveprotocol/protocol": "workspace:*",
    "semver": "^7.7.4",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.5.14"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "node ../../scripts/clean.mjs",
    "test": "vitest run test"
  }
}
